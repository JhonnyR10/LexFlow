{
  "name": "lexflow",
  "version": "0.1.0",
  "description": "Gestionale desktop per la tracciabilità delle istanze di liquidazione e notule spese",
  "private": true,
  "main": "./out/main/index.js",
  "author": "Giovanni Longo",
  "scripts": {
    "dev": "electron-vite dev",
    "desktop": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "lint": "eslint --cache .",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "rebuild": "electron-rebuild -f -w better-sqlite3-multiple-ciphers",
    "postinstall": "electron-rebuild -f -w better-sqlite3-multiple-ciphers"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@tanstack/react-query": "^5.101.1",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "playwright-core": "^1.61.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
